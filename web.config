<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config – IIS configuration for QNet Agent
  
  This uses HttpPlatformHandler to launch Waitress (a production WSGI
  server) and have IIS reverse-proxy traffic into it.
  
  PREREQUISITES on the Windows Server:
    1. IIS installed with HttpPlatformHandler v1.2+
    2. Python 3.11+ installed (e.g. C:\Python311\python.exe)
    3. Virtual environment created at .\venv
    4. pip install -r requirements.txt   (inside the venv)
    5. Copy .env.example → .env and fill in OPENAI_API_KEY + SECRET_KEY
    
  Adjust the paths below to match YOUR server.
-->
<configuration>
  <system.webServer>

    <!-- ── HttpPlatformHandler ──────────────────────────────────────
         IIS starts run_server.py via the venv Python interpreter.
         It picks a free port, sets %HTTP_PLATFORM_PORT%, and proxies
         all inbound traffic to that port.
    -->
    <handlers>
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform processPath="%HOME%\venv\Scripts\python.exe"
                  arguments="%HOME%\run_server.py"
                  stdoutLogEnabled="true"
                  stdoutLogFile="%HOME%\logs\iis-stdout.log"
                  startupTimeLimit="120"
                  requestTimeout="00:05:00"
                  processesPerApplication="1">
      <environmentVariables>
        <environmentVariable name="HOME" value="%HOME%" />
      </environmentVariables>
    </httpPlatform>

    <!-- ── Static files – let IIS serve them directly (faster) ──── -->
    <staticContent>
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".json"  mimeType="application/json" />
    </staticContent>

    <!-- ── Security headers ─────────────────────────────────────── -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

    <!-- ── Request limits (the /api/fetch-latest call can be slow) → -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
