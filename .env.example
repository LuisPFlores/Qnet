# QNet Agent - Environment Variables
# Copy this file to .env and fill in your actual keys

# OpenAI API key (required for summarization and topic analysis)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# IEEE Xplore API key (optional, enables IEEE source)
IEEE_API_KEY=

# Flask settings
SECRET_KEY=change-this-to-a-random-string
FLASK_DEBUG=1

# Collector settings
MAX_RESULTS_PER_SOURCE=20
REQUEST_TIMEOUT=30
